  },
  "hint": {
    "en": "Triggers when a system fault is detected",
    "nl": "Wordt geactiveerd wanneer een systeem storing wordt gedetecteerd",
    "de": "Wird ausgelöst, wenn eine Systemstörung erkannt wird",
    "fr": "Se déclenche lorsqu'un défaut du système est détecté"
  },
  "highlight": true,
  "args": [
    {
      "type": "device",
      "name": "device",
