    },
    {
      "type": "text",
      "name": "fault_code",
      "title": {
        "en": " code",
        "nl": " code",
        "de": " code",
        "fr": " code"
      },
      "placeholder": {
        "en": "Fault code to monitor, e.g. F1.1 or SYS1_1",
        "nl": "Storingscode om te monitoren, bijv. F1.1 of SYS1_1",
        "de": "Störungscode zur Überwachung, z. B. F1.1 oder SYS1_1",
        "fr": "Code de défaut à surveiller, p. ex. F1.1 ou SYS1_1"
      }
    }
  ],
  "tokens": [
    {
      "type": "string",
      "name": "fault_code",
      "title": {
        "en": "Fault code",
        "nl": "Storing code",
        "de": "Störungscode",
        "fr": "Code de défaut"
      },
      "example": "F1.1"
    },
    {
      "type": "string",
      "name": "fault_description",
      "title": {
        "en": "Fault description",
        "nl": "Storing beschrijving",
        "de": "Störungsbeschreibung",
