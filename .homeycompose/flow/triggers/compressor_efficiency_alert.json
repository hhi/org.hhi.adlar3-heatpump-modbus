{
  "id": "compressor_efficiency_alert",
  "title": {
    "en": "Compressor efficiency alert (Expert)",
    "nl": "Compressor efficiëntie alarm (Expert)",
    "de": "Kompressor-Effizienzalarm (Experte)",
    "fr": "Alerte d'efficacité du compresseur (Expert)"
  },
  "titleFormatted": {
    "en": "Compressor frequency [[condition]] [[frequency]] Hz (Expert)",
    "nl": "Compressor frequentie [[condition]] [[frequency]] Hz (Expert)",
