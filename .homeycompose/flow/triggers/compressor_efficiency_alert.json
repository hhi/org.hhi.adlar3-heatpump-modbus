    "fr": "Fréquence du compresseur [[condition]] [[frequency]] Hz (Expert)"
  },
  "hint": {
    "en": "Triggers when compressor frequency goes above or below a specified level. Requires 'Enable expert feature cards' in device settings.",
    "nl": "Wordt geactiveerd wanneer compressor frequentie boven of onder een bepaald niveau gaat. Vereist 'Expert functie kaarten inschakelen' in apparaat instellingen.",
    "de": "Wird ausgelöst, wenn die Kompressor-Frequenz einen angegebenen Schwellenwert über- oder unterschreitet. Erfordert 'Expertenfunktionskarten aktivieren' in den Geräteeinstellungen.",
    "fr": "Se déclenche lorsque la fréquence du compresseur dépasse ou descend en dessous d'un niveau spécifié. Nécessite 'Activer les cartes de fonctionnalités d'expert' dans les paramètres de l'appareil."
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=intelligent-heatpump-modbus&capabilities=adlar_cop"
    },
    {
      "type": "dropdown",
      "name": "condition",
      "title": {
        "en": "Condition",
        "nl": "Conditie",
        "de": "Bedingung",
        "fr": "Condition"
      },
      "values": [
        {
          "id": "above",
          "title": {
            "en": "above",
            "nl": "boven",
            "de": "über",
            "fr": "au-dessus"
          }
        },
        {
          "id": "below",
          "title": {
            "en": "below",
            "nl": "onder",
            "de": "unter",
            "fr": "en dessous"
          }
        }
      ]
    },
    {
      "type": "range",
      "name": "frequency",
      "title": {
        "en": " Frequency ",
        "nl": " Frequentie ",
        "de": " Frequenz ",
        "fr": " Fréquence "
      },
      "min": 10,
      "max": 200,
      "step": 5,
      "units": "Hz",
      "placeholder": {
        "en": "Frequency threshold in Hz",
        "nl": "Frequentie drempel in Hz",
        "de": "Frequenzschwellenwert in Hz",
        "fr": "Seuil de fréquence en Hz"
      }
    }
  ],
  "tokens": [
    {
      "type": "number",
      "name": "current_frequency",
      "title": {
        "en": "Current frequency",
        "nl": "Huidige frequentie",
        "de": "Aktuelle Frequenz",
