      },
      "example": 85
    },
    {
      "type": "number",
      "name": "threshold_frequency",
      "title": {
        "en": "Threshold frequency",
        "nl": "Drempel frequentie",
        "de": "Schwellenwert Frequenz",
        "fr": "Fréquence seuil"
      },
      "example": 90
    }
  ]
